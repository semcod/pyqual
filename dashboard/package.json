{
  "name": "pyqual-dashboard",
  "version": "1.0.0",
  "description": "Dashboard for visualizing Pyqual quality metrics",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "gh-pages -d dist -t true",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.8.0",
    "recharts": "^2.5.0",
    "date-fns": "^2.29.3",
    "@heroicons/react": "^2.0.18",
    "clsx": "^1.2.1"
  },
  "devDependencies": {
    "@types/react": "^18.0.27",
    "@types/react-dom": "^18.0.10",
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.14",
    "gh-pages": "^5.0.0",
    "postcss": "^8.4.21",
    "tailwindcss": "^3.2.7",
    "typescript": "^4.9.5",
    "vite": "^4.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/user-event": "^14.4.3",
    "vitest": "^0.28.5",
    "@vitest/ui": "^0.28.5",
    "@vitest/coverage-c8": "^0.28.5",
    "jsdom": "^21.1.0"
  },
  "homepage": "https://your-org.github.io/pyqual-dashboard"
}
