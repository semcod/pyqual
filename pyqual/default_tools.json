{
  "ruff": {
    "binary": "ruff",
    "command": "ruff check {workdir} --output-format=json",
    "output": ".pyqual/ruff.json"
  },
  "pylint": {
    "binary": "pylint",
    "command": "pylint --output-format=json {workdir}",
    "output": ".pyqual/pylint.json"
  },
  "flake8": {
    "binary": "flake8",
    "command": "flake8 --format=json {workdir}",
    "output": ".pyqual/flake8.json"
  },
  "mypy": {
    "binary": "mypy",
    "command": "mypy --output=json {workdir}",
    "output": ".pyqual/mypy.json"
  },
  "interrogate": {
    "binary": "interrogate",
    "command": "interrogate --generate-badge=never --format=json {workdir}",
    "output": ".pyqual/interrogate.json"
  },
  "radon": {
    "binary": "radon",
    "command": "radon mi {workdir} -j",
    "output": ".pyqual/radon.json"
  },
  "bandit": {
    "binary": "bandit",
    "command": "bandit -r {workdir} -f json -o .pyqual/bandit.json",
    "output": ""
  },
  "pip-audit": {
    "binary": "pip-audit",
    "command": "pip-audit --format=json --output=.pyqual/vulns.json",
    "output": ""
  },
  "detect-secrets": {
    "binary": "detect-secrets",
    "command": "detect-secrets scan --all-files --force-use-all-plugins > .pyqual/secrets.json",
    "output": ".pyqual/secrets.json",
    "allow_failure": true
  },
  "trufflehog": {
    "binary": "trufflehog",
    "command": "trufflehog git file://{workdir} --json",
    "output": ".pyqual/secrets.json"
  },
  "gitleaks": {
    "binary": "gitleaks",
    "command": "gitleaks detect --source {workdir} --report-format json --report-path .pyqual/secrets.json",
    "output": ""
  },
  "safety": {
    "binary": "safety",
    "command": "safety check --json",
    "output": ".pyqual/safety.json"
  },
  "pytest": {
    "binary": "pytest",
    "command": "pytest --cov=pyqual --cov-branch --cov-report=json:.pyqual/coverage.json -q",
    "output": "",
    "allow_failure": false
  },
  "code2llm": {
    "binary": "code2llm",
    "command": "code2llm {workdir} -f all -o ./project --no-chunk",
    "output": "",
    "allow_failure": false
  },
  "code2llm-filtered": {
    "binary": "code2llm",
    "command": "code2llm {workdir} -f toon -o ./project --no-chunk --exclude .git .venv .venv_test build dist __pycache__ .pytest_cache .code2llm_cache .benchmarks .mypy_cache .ruff_cache node_modules",
    "output": "",
    "allow_failure": true
  },
  "vallm": {
    "binary": "vallm",
    "command": "vallm batch {workdir} --recursive --format toon --output ./project",
    "output": "",
    "allow_failure": false
  },
  "vallm-filtered": {
    "binary": "vallm",
    "command": "vallm batch {workdir} --recursive --format toon --output ./project --exclude .git,.venv,.venv_test,build,dist,__pycache__,.pytest_cache,.code2llm_cache,.benchmarks,.mypy_cache,.ruff_cache,node_modules",
    "output": "",
    "allow_failure": true
  },
  "vallm-verify": {
    "binary": "vallm",
    "command": "vallm batch {workdir} --recursive --no-complexity --format toon --output ./project/verify --exclude .git,.venv,.venv_test,build,dist,__pycache__,.pytest_cache,.code2llm_cache,.benchmarks,.mypy_cache,.ruff_cache,node_modules",
    "output": "",
    "allow_failure": true
  },
  "code2docs": {
    "binary": "code2docs",
    "command": "code2docs {workdir} --readme-only",
    "output": ""
  },
  "redup": {
    "binary": "redup",
    "command": "redup scan {workdir} --format toon --output ./project",
    "output": ""
  },
  "prefact": {
    "binary": "prefact",
    "command": "prefact -a -e examples",
    "output": ""
  },
  "llx-fix": {
    "binary": "llx",
    "command": "llx fix . --apply $([ -f TODO.md ] && echo '--errors TODO.md')",
    "output": ""
  },
  "llx-fix-json": {
    "binary": "llx",
    "command": "llx fix . --apply $([ -f .pyqual/errors.json ] && echo '--errors .pyqual/errors.json')",
    "output": ""
  },
  "aider": {
    "binary": "aider",
    "command": "aider --yes-always --message \"$(cat TODO.md 2>/dev/null || echo 'Fix all issues')\"",
    "output": ""
  },
  "cyclonedx": {
    "binary": "cyclonedx-py",
    "command": "cyclonedx-py -r -o .pyqual/sbom.json",
    "output": ""
  },
  "report": {
    "binary": "python3",
    "command": "python3 -m pyqual.report --workdir {workdir}",
    "output": ""
  },
  "markdown-report": {
    "binary": "python3",
    "command": "python3 -m pyqual.report_generator",
    "output": "",
    "allow_failure": true
  },
  "markdown_report": {
    "binary": "python3",
    "command": "python3 -m pyqual.report_generator",
    "output": "",
    "allow_failure": true
  },
  "git-push": {
    "binary": "sh",
    "command": "sh -c 'if [ -n \"$(git status --porcelain)\" ]; then git add -A && git commit -m \"chore: pyqual auto-commit [skip ci]\" 2>/dev/null || true && git push origin HEAD; else echo \"No changes to push\"; fi'",
    "output": "",
    "allow_failure": true
  },
  "git-commit": {
    "binary": "sh",
    "command": "sh -c 'if [ -n \"$(git status --porcelain)\" ]; then git add -A && git commit -m \"chore: pyqual auto-commit [skip ci]\" 2>/dev/null || true; else echo \"Nothing to commit\"; fi'",
    "output": "",
    "allow_failure": true
  },
  "make-publish": {
    "binary": "make",
    "command": "make publish",
    "output": "",
    "allow_failure": true
  },
  "twine-publish": {
    "binary": "twine",
    "command": "twine upload dist/* --skip-existing",
    "output": "",
    "allow_failure": true
  },
  "attack-merge": {
    "binary": "python3",
    "command": "python3 -m pyqual.plugins.attack",
    "output": ".pyqual/attack_merge.json",
    "allow_failure": true
  },
  "close-tasks": {
    "binary": "python3",
    "command": "python3 -m pyqual.auto_closer",
    "output": "",
    "allow_failure": true
  },
  "todo-fix": {
    "binary": "python3",
    "command": "python3 -m pyqual.run_parallel_fix",
    "output": "",
    "allow_failure": true
  },
  "setup-deps": {
    "binary": "python3",
    "command": "python3 -m pyqual.setup_deps",
    "output": "",
    "allow_failure": true
  }
}
